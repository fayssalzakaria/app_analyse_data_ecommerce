# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.Python

# ---- Environnements virtuels ----
.venv/
venv/
env/
ENV/

# ---- Streamlit / secrets ----
.streamlit/secrets.toml

# ---- Secrets / variables d'environnement ----
.env
.env.*
*.secret

# ---- Caches & artefacts runtime (régénérés automatiquement) ----
data/cache/*
!data/cache/.gitkeep
data/jobs/
data/llm_audit/
data/llm_audit/*
data/exports/
# Artefacts de cache, où qu'ils soient
*.pkl
*.npy
.ipynb_checkpoints/
*.tmp
*.bak

# ---- Données : NE JAMAIS committer de données réelles / volumineuses ----
# (seul le jeu de démo data/sample/*.csv est versionné)
data/livrables/*.parquet
!data/livrables/.gitkeep
# Classeurs Excel exclus partout (racine et sous-dossiers)
*.xlsb
*.xls
*.xlsx

# ---- Outils de dev non nécessaires à l'app (gardés en local) ----
scripts/

# ---- OS / IDE ----
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/
*.log
